# Copy to .env and fill in values. Never commit .env.

# App
# APP_NAME=my-project
# APP_ENV=local
# LOG_LEVEL=info

# MongoDB (when used)
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=app

# MySQL (when used)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=app
# MYSQL_PASSWORD=changeme
# MYSQL_DATABASE=app
