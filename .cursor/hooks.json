{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/guard-push.sh",
        "matcher": "git push"
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-context.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-on-edit.sh"
      }
    ]
  }
}
