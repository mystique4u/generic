{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/enforce-git-flow.sh",
        "matcher": "git\\s+",
        "failClosed": true
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-context.sh",
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format-on-edit.sh",
        "failClosed": false
      }
    ]
  }
}
